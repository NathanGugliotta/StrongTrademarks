# Postgres connection string (e.g. from Neon, Supabase, Railway, or local Docker)
DATABASE_URL=postgres://user:password@localhost:5432/strongtrademarks

# Next.js server actions — set a stable encryption key so server action IDs
# stay consistent across deploys. Without this, users with stale tabs hit
# "Server Action ... was not found" errors after every deploy. Generate
# with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Auth.js — required.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Email — optional in dev.
# If EMAIL_SERVER is unset, magic-link sign-in URLs are logged to the server
# console instead of emailed. Once set, real emails are sent via Nodemailer.
# Example: smtp://username:password@smtp.example.com:587
EMAIL_SERVER=
EMAIL_FROM=noreply@strongtrademarks.com

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Vercel Cron — Vercel auto-generates this on first deploy with cron config.
# Used by /api/cron/deadline-reminders to authenticate scheduled requests.
# For local testing of the cron route, set to any string and pass as
# `Authorization: Bearer <value>` header.
CRON_SECRET=

# Vercel Blob — required for file uploads (specimens, drawings).
# Create a Blob store at https://vercel.com/dashboard/stores and copy the
# read-write token here. For local dev against an existing store, run:
#   vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=

# Google Sheets sync for the firm docket — required for docket assignment.
# DOCKET_SHEET_ID is the long ID in the spreadsheet URL between /d/ and /edit.
# GOOGLE_SERVICE_ACCOUNT_KEY_BASE64 is the entire JSON key file, base64-encoded
# (paste-friendly for Vercel). On macOS:  base64 -i key.json | pbcopy
DOCKET_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# Google Calendar — optional. When set, paid applications add an event to
# the firm's intake calendar so attorneys see them in their normal calendar
# view. Create a dedicated calendar (e.g. "Strong Trademarks Intake"),
# share it with the same service account email (above) with "Make changes
# to events" permission, then paste its Calendar ID here. Find the ID
# under Calendar settings → Integrate calendar → Calendar ID.
INTAKE_CALENDAR_ID=

# Google Drive — optional. When set, paid applications get an auto-created
# WRAPPER folder in Google Drive matching the firm's manual naming
# convention ("Last, First DOCKET (Mark)"). Set this to the parent
# folder's ID — the one that contains all client WRAPPERs at your firm.
# Find it in the URL: drive.google.com/drive/folders/<this_part>. Share
# that folder with the same service account email (above) with Editor
# permission, and enable the Google Drive API in Cloud Console.
WRAPPER_DRIVE_FOLDER_ID=

# Domain-wide delegation — required for Drive writes if WRAPPER lives in a
# normal "My Drive" folder rather than a Shared Drive. Service accounts have
# zero personal Drive quota, so any file the SA creates fails unless it's
# impersonating a real Workspace user. Set this to the email of that user
# (the firm's primary Workspace account is fine). Setup also requires
# enabling domain-wide delegation for the service account in the Workspace
# admin console with scope https://www.googleapis.com/auth/drive.
GOOGLE_IMPERSONATE_EMAIL=

# USPTO TSDR (Trademark Status & Document Retrieval) — required for the
# daily lifecycle poll once an application is filed. Request a free key at
# developer.uspto.gov. Without this set, the cron logs a warning and skips.
USPTO_TSDR_API_KEY=

# Pricing (cents)
TRADEMARK_FEE_CENTS=49900
